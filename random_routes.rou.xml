import xml.etree.ElementTree as ET
import random
import numpy as np
from scipy import stats
from typing import List, Tuple, Dict, Any
import json

class StochasticTrafficGenerator:
    """
    Generates random traffic flows for PPO training with various distribution patterns
    """
    
    def __init__(self, reference_routes_file: str, seed: int = None):
        """Extract valid OD pairs and vehicle types from reference file"""
        if seed is not None:
            np.random.seed(seed)
            random.seed(seed)
            
        tree = ET.parse(reference_routes_file)
        root = tree.getroot()
        
        # Extract valid pairs and types
        self.valid_pairs = []
        self.vehicle_types = set()
        
        for flow in root.findall('flow'):
            from_edge = flow.get('from')
            to_edge = flow.get('to')
            veh_type = flow.get('type')
            
            if from_edge and to_edge:
                self.valid_pairs.append((from_edge, to_edge))
            if veh_type:
                self.vehicle_types.add(veh_type)
        
        # Remove duplicates while preserving order
        self.valid_pairs = list(dict.fromkeys(self.valid_pairs))
        self.vehicle_types = list(self.vehicle_types)
        
        print(f"Loaded {len(self.valid_pairs)} valid OD pairs")
        print(f"Vehicle types: {self.vehicle_types}")
        
    def generate_flow_with_distribution(self, 
                                        distribution: str = 'uniform',
                                        **params) -> Dict[str, Any]:
        """
        Generate a single flow using specified distribution
        
        Distributions:
        - 'uniform': Uniform random
        - 'normal': Normal/Gaussian distribution
        - 'poisson': Poisson process
        - 'exponential': Exponential distribution (for inter-arrival times)
        - 'lognormal': Log-normal distribution
        - 'gamma': Gamma distribution
        - 'bimodal': Two-peak distribution (rush hours)
        - 'pareto': Pareto distribution (heavy-tailed)
        - 'uniform_periodic': Uniform with periodic patterns
        """
        
        # Randomly select OD pair and vehicle type
        from_edge, to_edge = random.choice(self.valid_pairs)
        veh_type = random.choice(self.vehicle_types)
        
        # Generate begin time based on distribution
        sim_duration = params.get('sim_duration', 5000)
        
        if distribution == 'uniform':
            begin = np.random.uniform(0, sim_duration * 0.8)
            duration = np.random.uniform(300, sim_duration - begin)
            end = min(begin + duration, sim_duration)
            period = np.random.uniform(2, 60)
            
        elif distribution == 'normal':
            # Normal distribution with optional peak hours
            mean = params.get('mean', sim_duration / 2)
            std = params.get('std', sim_duration / 6)
            begin = np.random.normal(mean, std)
            begin = np.clip(begin, 0, sim_duration * 0.9)
            
            duration_mean = params.get('duration_mean', 1000)
            duration_std = params.get('duration_std', 300)
            duration = np.random.normal(duration_mean, duration_std)
            end = min(begin + abs(duration), sim_duration)
            
            period_mean = params.get('period_mean', 15)
            period_std = params.get('period_std', 5)
            period = abs(np.random.normal(period_mean, period_std))
            period = np.clip(period, 1, 60)
            
        elif distribution == 'poisson':
            # Poisson process for arrivals
            begin = np.random.uniform(0, sim_duration * 0.7)
            duration = np.random.uniform(500, 2000)
            end = min(begin + duration, sim_duration)
            
            # Lambda = arrival rate (vehicles per second)
            lambda_rate = np.random.exponential(scale=0.05)  # mean 0.05 veh/sec = 1 every 20 sec
            period = 1.0 / max(lambda_rate, 0.01)  # Convert to period
            
        elif distribution == 'exponential':
            begin = np.random.exponential(scale=sim_duration / 4)
            begin = min(begin, sim_duration * 0.8)
            
            duration = np.random.exponential(scale=800)
            end = min(begin + duration, sim_duration)
            
            period = np.random.exponential(scale=10)
            period = np.clip(period, 1, 60)
            
        elif distribution == 'lognormal':
            begin = np.random.lognormal(mean=np.log(sim_duration/3), sigma=0.8)
            begin = min(begin, sim_duration * 0.9)
            
            duration = np.random.lognormal(mean=np.log(800), sigma=0.5)
            end = min(begin + duration, sim_duration)
            
            period = np.random.lognormal(mean=np.log(15), sigma=0.7)
            period = np.clip(period, 1, 60)
            
        elif distribution == 'gamma':
            begin = np.random.gamma(shape=2, scale=sim_duration/6)
            begin = min(begin, sim_duration * 0.85)
            
            duration = np.random.gamma(shape=2, scale=400)
            end = min(begin + duration, sim_duration)
            
            period = np.random.gamma(shape=2, scale=8)
            period = np.clip(period, 1, 50)
            
        elif distribution == 'bimodal':
            # Two peaks (morning and evening rush)
            peak_choice = np.random.choice([0, 1], p=[0.5, 0.5])
            if peak_choice == 0:  # Morning peak (6-9 AM -> 600-900)
                begin = np.random.normal(750, 100)
            else:  # Evening peak (4-7 PM -> 1600-1900)
                begin = np.random.normal(1750, 100)
            begin = np.clip(begin, 0, sim_duration * 0.85)
            
            duration = np.random.uniform(300, 800)
            end = min(begin + duration, sim_duration)
            
            # Shorter periods during peaks
            period = np.random.gamma(shape=1.5, scale=3)
            period = np.clip(period, 2, 15)
            
        elif distribution == 'pareto':
            # Heavy-tailed distribution (occasional bursts)
            begin = (np.random.pareto(2) + 1) * (sim_duration / 10)
            begin = min(begin, sim_duration * 0.85)
            
            duration = (np.random.pareto(1.5) + 1) * 300
            end = min(begin + duration, sim_duration)
            
            period = (np.random.pareto(2) + 1) * 8
            period = np.clip(period, 1, 80)
            
        elif distribution == 'uniform_periodic':
            # Uniform with sine wave pattern
            begin = np.random.uniform(0, sim_duration * 0.8)
            duration = np.random.uniform(500, 1500)
            end = min(begin + duration, sim_duration)
            
            # Periodic variation in period
            t = begin / sim_duration
            base_period = 20
            amplitude = 15
            period = base_period + amplitude * np.sin(2 * np.pi * t * 3)
            period += np.random.normal(0, 2)  # Add noise
            period = np.clip(period, 3, 50)
            
        else:
            raise ValueError(f"Unknown distribution: {distribution}")
        
        return {
            'from': from_edge,
            'to': to_edge,
            'begin': float(begin),
            'end': float(end),
            'period': float(period),
            'type': veh_type,
            'distribution': distribution
        }
    
    def generate_training_episode(self, 
                                  num_flows: int = 30,
                                  mixed_distributions: bool = True,
                                  distribution_weights: Dict[str, float] = None) -> str:
        """
        Generate a complete training episode with mixed randomness
        
        Args:
            num_flows: Number of flows to generate
            mixed_distributions: If True, mix multiple distribution types
            distribution_weights: Custom weights for distributions (e.g., {'normal': 0.3, 'poisson': 0.3, 'bimodal': 0.4})
        """
        
        if distribution_weights is None:
            # Default weights for training robustness
            distribution_weights = {
                'uniform': 0.15,
                'normal': 0.20,
                'poisson': 0.15,
                'exponential': 0.10,
                'lognormal': 0.10,
                'gamma': 0.10,
                'bimodal': 0.15,
                'pareto': 0.05
            }
        
        distributions = list(distribution_weights.keys())
        weights = list(distribution_weights.values())
        
        flows = []
        flow_metadata = []
        
        for i in range(num_flows):
            if mixed_distributions:
                # Sample distribution type based on weights
                dist_type = np.random.choice(distributions, p=weights)
            else:
                # Use single distribution for all flows (for ablation studies)
                dist_type = 'normal'  # or any default
            
            # Generate flow parameters
            flow_params = self.generate_flow_with_distribution(dist_type)
            
            # Create XML element
            flow_elem = ET.Element('flow')
            flow_elem.set('id', f'flow_{i}_{dist_type}')
            flow_elem.set('from', flow_params['from'])
            flow_elem.set('to', flow_params['to'])
            flow_elem.set('begin', f"{flow_params['begin']:.1f}")
            flow_elem.set('end', f"{flow_params['end']:.1f}")
            flow_elem.set('period', f"{flow_params['period']:.2f}")
            flow_elem.set('type', flow_params['type'])
            
            flows.append(flow_elem)
            flow_metadata.append(flow_params)
        
        return flows, flow_metadata
    
    def generate_adaptive_difficulty(self, 
                                    episode_num: int,
                                    base_flows: int = 30,
                                    difficulty_curve: str = 'exponential') -> Tuple[List, List]:
        """
        Generate episodes with increasing difficulty for curriculum learning
        
        Args:
            episode_num: Current episode number (0-indexed)
            base_flows: Base number of flows
            difficulty_curve: 'linear', 'exponential', or 'step'
        """
        
        # Increase flow count and density with episode number
        if difficulty_curve == 'linear':
            flow_multiplier = 1 + episode_num * 0.02
            density_multiplier = 1 + episode_num * 0.03
        elif difficulty_curve == 'exponential':
            flow_multiplier = np.exp(episode_num * 0.01)
            density_multiplier = np.exp(episode_num * 0.015)
        elif difficulty_curve == 'step':
            # Step function every 50 episodes
            step = episode_num // 50
            flow_multiplier = 1 + step * 0.3
            density_multiplier = 1 + step * 0.4
        
        num_flows = int(base_flows * min(flow_multiplier, 5.0))  # Cap at 5x
        
        # Adjust distribution weights for harder episodes
        if episode_num < 30:
            # Early episodes: predictable patterns
            weights = {'uniform': 0.4, 'normal': 0.4, 'poisson': 0.2}
        elif episode_num < 100:
            # Medium: more variety
            weights = {'uniform': 0.2, 'normal': 0.3, 'poisson': 0.2, 
                      'exponential': 0.1, 'gamma': 0.1, 'bimodal': 0.1}
        else:
            # Hard: chaotic, heavy-tailed distributions
            weights = {'pareto': 0.3, 'lognormal': 0.2, 'exponential': 0.2,
                      'bimodal': 0.2, 'gamma': 0.1}
        
        # Adjust periods to be shorter (more traffic) as difficulty increases
        flows = []
        for i in range(num_flows):
            dist_type = np.random.choice(list(weights.keys()), p=list(weights.values()))
            flow_params = self.generate_flow_with_distribution(dist_type)
            
            # Scale down period for higher density (only if not already short)
            flow_params['period'] = max(1.0, flow_params['period'] / density_multiplier)
            
            # Create XML element
            flow_elem = ET.Element('flow')
            flow_elem.set('id', f'ep{episode_num}_flow{i}')
            flow_elem.set('from', flow_params['from'])
            flow_elem.set('to', flow_params['to'])
            flow_elem.set('begin', f"{flow_params['begin']:.1f}")
            flow_elem.set('end', f"{flow_params['end']:.1f}")
            flow_elem.set('period', f"{flow_params['period']:.2f}")
            flow_elem.set('type', flow_params['type'])
            
            flows.append(flow_elem)
        
        return flows, flow_params  # flow_params not used here
    
    def save_episode(self, 
                    flows: List[ET.Element], 
                    filename: str,
                    episode_metadata: Dict = None):
        """Save flows to SUMO route file"""
        
        root = ET.Element('routes')
        root.set('xmlns:xsi', 'http://www.w3.org/2001/XMLSchema-instance')
        root.set('xsi:noNamespaceSchemaLocation', 'http://sumo.dlr.de/xsd/routes_file.xsd')
        
        for flow in flows:
            root.append(flow)
        
        tree = ET.ElementTree(root)
        ET.indent(tree, space='  ')
        tree.write(filename, encoding='UTF-8', xml_declaration=True)
        
        # Save metadata if provided
        if episode_metadata:
            meta_filename = filename.replace('.rou.xml', '_metadata.json')
            with open(meta_filename, 'w') as f:
                json.dump(episode_metadata, f, indent=2)

# Training loop integration
class PPOTrainingEnvironment:
    """
    Wrapper for PPO training that generates fresh random scenarios each episode
    """
    
    def __init__(self, reference_routes_file: str, sumo_network_file: str):
        self.generator = StochasticTrafficGenerator(reference_routes_file)
        self.network_file = sumo_network_file
        self.episode_count = 0
        
    def reset(self, mode: str = 'mixed', **kwargs):
        """Generate new random traffic pattern for next episode"""
        
        self.episode_count += 1
        
        if mode == 'mixed':
            flows, metadata = self.generator.generate_training_episode(
                num_flows=kwargs.get('num_flows', 30),
                mixed_distributions=True
            )
        elif mode == 'curriculum':
            flows, _ = self.generator.generate_adaptive_difficulty(
                episode_num=self.episode_count,
                base_flows=kwargs.get('base_flows', 30)
            )
        elif mode == 'single_distribution':
            # For testing specific distribution
            dist = kwargs.get('distribution', 'normal')
            flows = []
            for i in range(kwargs.get('num_flows', 30)):
                flow_params = self.generator.generate_flow_with_distribution(dist)
                flow_elem = ET.Element('flow')
                flow_elem.set('id', f'flow_{i}')
                flow_elem.set('from', flow_params['from'])
                flow_elem.set('to', flow_params['to'])
                flow_elem.set('begin', f"{flow_params['begin']:.1f}")
                flow_elem.set('end', f"{flow_params['end']:.1f}")
                flow_elem.set('period', f"{flow_params['period']:.2f}")
                flow_elem.set('type', flow_params['type'])
                flows.append(flow_elem)
            metadata = []
        
        # Save episode configuration
        route_file = f'episode_{self.episode_count:05d}.rou.xml'
        self.generator.save_episode(flows, route_file, {
            'episode': self.episode_count,
            'mode': mode,
            'num_flows': len(flows),
            'metadata': metadata
        })
        
        return route_file, metadata

